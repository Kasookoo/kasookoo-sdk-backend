							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/webrtc/calls/{{room_name}}/end",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "webrtc", "calls", "{{room_name}}", "end"]
						},
						"description": "End an active call session"
					}
				},
				{
					"name": "Get Call Status",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{static_api_key}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/webrtc/calls/{{room_name}}/status",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "webrtc", "calls", "{{room_name}}", "status"]
						},
						"description": "Get current call status and recording information"
					}
				},
