								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{static_api_key}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"participant_identity\": \"called_user_456\",\n  \"participant_identity_name\": \"Jane Smith\",\n  \"participant_identity_type\": \"customer\",\n  \"room_name\": \"call_room_123\",\n  \"called_user_id\": \"called_user_456\",\n  \"is_call_recording\": true\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/webrtc/get-called-token",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "webrtc", "get-called-token"]
						},
