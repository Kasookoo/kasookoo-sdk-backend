					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{static_api_key}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/webrtc/calls",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "webrtc", "calls"]
						},
						"description": "List all active calls"
					}
				},
				{
					"name": "Reject Call",
