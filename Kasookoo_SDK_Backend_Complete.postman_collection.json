{
	"info": {
		"_postman_id": "kasookoo-sdk-backend-complete",
		"name": "Kasookoo SDK Backend - Complete API Collection",
		"description": "Complete API collection for Kasookoo SDK Backend including Authentication, WebRTC, SDK SIP (LiveKit bridge at /api/v1/bot/sdk-sip), Notifications, and Monitoring endpoints. SIP routes calls/make, calls/end, rooms/token, and sip/trunks require a Kasookoo SDK JWT (collection variable sdk_access_token). calls/dial and calls/hangup use STATIC_API_KEY (static_api_key).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "kasookoo-sdk"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Create Client Session (SDK JWT)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"try {",
									"    var j = pm.response.json();",
									"    if (j && j.token) {",
									"        pm.collectionVariables.set('sdk_access_token', j.token);",
									"        console.log('Saved token to sdk_access_token');",
									"    }",
									"} catch (e) { console.warn(e); }"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"sub\": \"postman_test_user\",\n  \"organization_id\": null,\n  \"email\": \"test@example.com\",\n  \"scopes\": [\"webrtc:token:create\"],\n  \"ttl_seconds\": 3600\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/sdk/auth/client-sessions",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "sdk", "auth", "client-sessions"]
						},
						"description": "Obtain a Kasookoo SDK JWT. On success, the Tests script stores the token in collection variable sdk_access_token for SIP and other JWT-protected routes."
					}
				},
				{
					"name": "Get Access Token (Deprecated)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "grant_type",
									"value": "password",
									"description": "OAuth2 grant type"
								},
								{
									"key": "username",
									"value": "fairmoney",
									"description": "Username for authentication"
								},
								{
									"key": "password",
									"value": "@@FairmonyKasookoo123456",
									"description": "Password for authentication"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}/token",
							"host": ["{{base_url}}"],
							"path": ["token"]
						},
						"description": "Login to get JWT access token (Deprecated - use static API key instead)"
					}
				}
			],
			"description": "Authentication endpoints. Use Create Client Session to populate sdk_access_token for JWT-protected APIs (including most SDK SIP routes)."
		},
		{
			"name": "WebRTC - Call Management",
			"item": [
				{
					"name": "Get Caller Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{static_api_key}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"participant_identity\": \"caller_user_123\",\n  \"participant_identity_name\": \"John Doe\",\n  \"participant_identity_type\": \"caller\",\n  \"room_name\": \"call_room_123\",\n  \"caller_user_id\": \"caller_user_123\",\n  \"called_user_id\": \"called_user_456\",\n  \"device_type\": \"mobile\",\n  \"is_push_notification\": true,\n  \"is_call_recording\": true\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/webrtc/get-caller-token",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "webrtc", "get-caller-token"]
						},
						"description": "Generate LiveKit access token for caller and initiate call session"
					}
				},
				{
					"name": "Get Called Token",
