		{
			"name": "SIP - Call Management",
			"item": [
				{
					"name": "Make Outbound Call",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{sdk_access_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone_number\": \"+1234567890\",\n  \"room_name\": \"sip_call_123\",\n  \"participant_name\": \"John Doe\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/bot/sdk-sip/calls/make",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "bot", "sdk-sip", "calls", "make"]
						},
						"description": "Initiate an outbound SIP call. Requires Kasookoo SDK JWT (Authorization: Bearer {{sdk_access_token}}). Run Authentication > Create Client Session first, or paste a token into the sdk_access_token collection variable."
					}
				},
				{
					"name": "Dial Outbound Call",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{static_api_key}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone_number\": \"+1234567890\",\n  \"room_name\": \"sip_call_123\",\n  \"participant_name\": \"John Doe\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/bot/sdk-sip/calls/dial",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "bot", "sdk-sip", "calls", "dial"]
						},
						"description": "Initiate an outbound SIP call (server-to-server). Uses STATIC_API_KEY (static_api_key), not the SDK JWT."
					}
				},
				{
					"name": "End SIP Call",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{sdk_access_token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"participant_identity\": \"user123\",\n  \"room_name\": \"sip_call_123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/bot/sdk-sip/calls/end",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "bot", "sdk-sip", "calls", "end"]
						},
						"description": "End an active SIP call. Requires Kasookoo SDK JWT (sdk_access_token)."
					}
				},
				{
					"name": "Hangup SIP Call",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{static_api_key}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"participant_identity\": \"user123\",\n  \"room_name\": \"sip_call_123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/bot/sdk-sip/calls/hangup",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "bot", "sdk-sip", "calls", "hangup"]
						},
						"description": "End an active SIP call (server-to-server). Uses STATIC_API_KEY (static_api_key), not the SDK JWT."
					}
				}
			],
			"description": "SDK SIP call management (/api/v1/bot/sdk-sip). make and end use SDK JWT; dial and hangup use static API key."
		},
