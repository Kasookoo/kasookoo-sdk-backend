					"name": "List Call Sessions",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{static_api_key}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/webrtc/call/sessions?search={{search_term}}&skip=0&limit=10",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "webrtc", "call", "sessions"],
							"query": [
								{
									"key": "search",
									"value": "{{search_term}}",
									"description": "Search by room_name, caller_id, or callee_id"
								},
								{
									"key": "skip",
									"value": "0",
									"description": "Number of records to skip"
								},
								{
									"key": "limit",
									"value": "10",
									"description": "Max records to return"
								}
