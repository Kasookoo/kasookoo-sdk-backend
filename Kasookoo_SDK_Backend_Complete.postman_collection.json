					}
				},
				{
					"name": "Update Device Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{static_api_key}}"
							}
						],
