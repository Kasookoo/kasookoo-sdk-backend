		{
			"name": "Notifications - Device Token Management",
			"item": [
				{
					"name": "Register Device Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{static_api_key}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"user_id\": \"user_123\",\n  \"user_type\": \"driver\",\n  \"device_token\": \"fcm_device_token_here\",\n  \"device_type\": \"android\",\n  \"new_device_token\": \"new_fcm_token_optional\",\n  \"device_info\": {\n    \"app_version\": \"1.0.0\",\n    \"os_version\": \"13.0\",\n    \"device_model\": \"Samsung Galaxy S21\"\n  }\n}"
						},
						"url": {
							"raw": "{{base_url}}/notifications/register-token",
							"host": ["{{base_url}}"],
							"path": ["notifications", "register-token"]
						},
